# Copy to .env.local and paste ONE key. Without either, the app runs in a limited "demo mode".
# The app prefers OpenAI when OPENAI_API_KEY is set; otherwise it uses ANTHROPIC_API_KEY.

# OpenAI (https://platform.openai.com/api-keys) — uses gpt-4o-mini
OPENAI_API_KEY=

# Anthropic (https://console.anthropic.com) — uses claude-haiku-4-5
ANTHROPIC_API_KEY=
